{
  "description": "Database safety: block non-SELECT SQL in db.sh and psql commands",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PLUGIN_ROOT/hooks/scripts/validate-sql.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
